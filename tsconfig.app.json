{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "noEmit": false,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "index.html"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**"
  ]
}